{
  "plugin": "org.smartide.plugin.nodejs",
  "run": "npm test",
  "gui": false,
  "intelligence": {
    ".json": {
      "enabled": true,
      "run": "vscode-json-language-server --stdio"
    },
    ".js": {
      "enabled": false,
      "run": "typescript-language-server --stdio"
    },
    ".ts": {
      "enabled": false,
      "run": "typescript-language-server --stdio"
    },
    ".yml": {
      "enabled": false,
      "run": "yaml-language-server --stdio"
    }
  }
}